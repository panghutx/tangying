generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  directUrl = env("DIRECT_URL")
}

enum AccountType {
  DOMESTIC    // 国内平台
  BANK        // 银行理财
  BROKERAGE   // 券商
  OVERSEAS    // 海外平台
}

enum IncomeType {
  PROFIT      // 收益
  DIVIDEND    // 分红
  INTEREST    // 利息
  FEE         // 手续费
}

enum SyncStatus {
  SUCCESS
  FAILED
  PENDING
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  image        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts     FinancialAccount[]
  assets       Asset[]
  incomes      Income[]

  @@map("users")
}

model FinancialAccount {
  id          String      @id @default(cuid())
  userId      String
  name        String
  type        AccountType
  platform    String
  credentials String?    // AES 加密存储
  currency    String      @default("CNY")
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets      Asset[]
  incomes     Income[]
  syncLogs    SyncLog[]

  @@map("financial_accounts")
}

model Asset {
  id        String   @id @default(cuid())
  accountId String
  userId    String
  date      DateTime @db.Date
  amount    Decimal  @db.Decimal(15, 2)
  currency  String   @default("CNY")
  note      String?
  createdAt DateTime @default(now())

  account   FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, date])
  @@map("assets")
}

model Income {
  id        String     @id @default(cuid())
  accountId String
  userId    String
  date      DateTime   @db.Date
  amount    Decimal    @db.Decimal(15, 2)
  type      IncomeType
  note      String?
  createdAt DateTime   @default(now())

  account   FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("incomes")
}

model SyncLog {
  id        String     @id @default(cuid())
  accountId String
  status    SyncStatus
  message   String?
  syncedAt  DateTime   @default(now())

  account   FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("sync_logs")
}
