generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String             @id @default(cuid())
  email        String             @unique
  passwordHash String?
  name         String?
  image        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  assets       Asset[]
  accounts     FinancialAccount[]
  incomes      Income[]
  transactions Transaction[]
  goals        Goal[]

  @@map("users")
}

model FinancialAccount {
  id                  String        @id @default(cuid())
  userId              String
  name                String
  type                AccountType
  platform            String
  credentials         String?
  currency            String        @default("CNY")
  isActive            Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  assets              Asset[]
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes             Income[]
  syncLogs            SyncLog[]
  transactions        Transaction[]
  relatedTransactions Transaction[] @relation("TransferRelation")

  @@map("financial_accounts")
}

model Asset {
  id        String           @id @default(cuid())
  accountId String
  userId    String
  date      DateTime         @db.Date
  amount    Decimal          @db.Decimal(15, 2)
  currency  String           @default("CNY")
  note      String?
  createdAt DateTime         @default(now())
  account   FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, date])
  @@map("assets")
}

model Income {
  id        String           @id @default(cuid())
  accountId String
  userId    String
  date      DateTime         @db.Date
  amount    Decimal          @db.Decimal(15, 2)
  type      IncomeType
  note      String?
  createdAt DateTime         @default(now())
  account   FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("incomes")
}

model SyncLog {
  id        String           @id @default(cuid())
  accountId String
  status    SyncStatus
  message   String?
  syncedAt  DateTime         @default(now())
  account   FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("sync_logs")
}

model Transaction {
  id               String            @id @default(cuid())
  accountId        String
  userId           String
  date             DateTime          @db.Date
  amount           Decimal           @db.Decimal(15, 2)
  type             TransactionType
  category         String?
  note             String?
  relatedAccountId String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  account          FinancialAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  relatedAccount   FinancialAccount? @relation("TransferRelation", fields: [relatedAccountId], references: [id])
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accountId, date])
  @@index([userId, date])
  @@map("transactions")
}

model Goal {
  id            String      @id @default(cuid())
  userId        String
  type          GoalType
  name          String
  targetAmount  Decimal     @db.Decimal(15, 2)
  period        GoalPeriod?
  deadline      DateTime?
  status        GoalStatus  @default(ACTIVE)
  createdAt     DateTime    @default(now())
  completedAt   DateTime?
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress      GoalProgress[]

  @@map("goals")
}

model GoalProgress {
  id            String   @id @default(cuid())
  goalId        String
  date          DateTime @db.Date
  currentAmount Decimal  @db.Decimal(15, 2)
  createdAt     DateTime @default(now())
  goal          Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, date])
  @@map("goal_progress")
}

enum AccountType {
  DOMESTIC
  BANK
  BROKERAGE
  OVERSEAS
}

enum IncomeType {
  PROFIT
  DIVIDEND
  INTEREST
  FEE
}

enum SyncStatus {
  SUCCESS
  FAILED
  PENDING
}

enum TransactionType {
  INCOME
  DEPOSIT
  WITHDRAW
  TRANSFER_IN
  TRANSFER_OUT
}

enum GoalType {
  ASSET
  PROFIT
}

enum GoalPeriod {
  MONTHLY
  YEARLY
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  FAILED
  ARCHIVED
}
